name: Secure Matrix Scan
on: [push]

jobs:
  # Running scans in parallel to save execution time
  security-audit:
    name: Code Analysis
    runs-on: ubuntu-latest
    permissions:
      actions: read
      contents: read
      security-events: write # Required to upload findings to the GitHub Security Tab

    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      # Example step targeting one of the repository's configuration setups
      - name: Run CodeQL Initialization
        uses: github/codeql-action/init@v3
        with:
          languages: 'javascript'
